{
  "name": "snapdrift",
  "version": "0.0.0-internal",
  "private": false,
  "type": "module",
  "description": "SnapDrift captures, compares, and reports UI drift for Playwright-based app checks.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ranacseruet/snapdrift.git"
  },
  "homepage": "https://github.com/ranacseruet/snapdrift#readme",
  "bugs": {
    "url": "https://github.com/ranacseruet/snapdrift/issues"
  },
  "author": "CodeSamplez",
  "keywords": [
    "snapdrift",
    "github-actions",
    "visual-regression",
    "ui-drift",
    "playwright",
    "screenshot-testing"
  ],
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "js-yaml": "^4.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "transform": {}
  },
  "exports": {
    "./lib/visual-regression-config.mjs": "./lib/visual-regression-config.mjs",
    "./lib/capture-visual-routes.mjs": "./lib/capture-visual-routes.mjs",
    "./lib/compare-visual-results.mjs": "./lib/compare-visual-results.mjs",
    "./lib/stage-visual-artifacts.mjs": "./lib/stage-visual-artifacts.mjs",
    "./lib/visual-diff-summary.mjs": "./lib/visual-diff-summary.mjs",
    "./lib/visual-diff-pr-comment.mjs": "./lib/visual-diff-pr-comment.mjs"
  },
  "files": [
    "actions/",
    "lib/",
    "types/",
    "docs/",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0"
  }
}
