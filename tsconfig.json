{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "types": ["node", "jest"],
    "skipLibCheck": true
  },
  "include": [
    "lib/**/*.mjs",
    "scripts/**/*.mjs"
  ]
}
