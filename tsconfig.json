{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "types": ["node", "jest"],
    "skipLibCheck": true
  },
  "include": [
    "lib/**/*.mjs",
    "scripts/**/*.mjs",
    "packages/*/src/**/*.mjs",
    "packages/*/types/*.d.ts",
    "packages/adapter-fs/src/**/*.mjs",
    "packages/adapter-fs/types/*.d.ts",
    "packages/adapter-report-md/src/**/*.mjs",
    "packages/adapter-report-md/types/*.d.ts"
  ]
}
